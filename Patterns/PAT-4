Input:
n=5

Output:
1
12
123
1234
12345

Solution:
public class Main {
    public static void main(String[] args) {
      int n=5;
      PatternOne(n);
    }
    public static void PatternOne(int n){
      for(int i=1;i<=n;i++){
        for(int j=1;j<=i;j++){
          System.out.print(j);
        }
        System.out.println();
      }
    }
}
