Input:
n=5

Output:
*
**
***
****
*****


Solution:
public class Main {
    public static void main(String[] args) {
      //Scanner scn=new Scanner(System.in);
      int n=5;
      PatternOne(n);
    }
    public static void PatternOne(int n){
      for(int i=0;i<n;i++){
        for(int j=0;j<=i;j++){
          System.out.print("*");
        }
        System.out.println();
      }
    }
}
