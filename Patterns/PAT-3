Input:
n=5

Output:
*****
****
***
**
*


Solution:

public class Main {
    public static void main(String[] args) {
      int n=5;
      PatternOne(n); //PatternOne is function name
    }
    public static void PatternOne(int n){
      for(int i=n;i>=0;i--){
        for(int j=0;j<i;j++){
          System.out.print("*");
        }
        System.out.println();
      }
    }
}
 
