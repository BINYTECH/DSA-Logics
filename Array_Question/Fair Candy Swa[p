import java.util.*;

class Solution {
    public int[] fairCandySwap(int[] aliceSizes, int[] bobSizes) {
        int sumA = 0, sumB = 0;
        Set<Integer> setB = new HashSet<>();

        // Calculate total sums and store Bob's sizes in a Set
        for (int x : aliceSizes) sumA += x;
        for (int y : bobSizes) {
            sumB += y;
            setB.add(y);
        }

        // The difference Bob's candy must have relative to Alice's
        int delta = (sumB - sumA) / 2;

        // Find the pair
        for (int x : aliceSizes) {
            int targetY = x + delta;
            if (setB.contains(targetY)) {
                return new int[]{x, targetY};
            }
        }
        
        return new int[0];
    }
}
